{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "aws/aws-sdk-php": "^3.283",
        "barryvdh/laravel-dompdf": "^2.0",
        "brokenice/laravel-mysql-partition": "^1.2",
        "doctrine/dbal": "^3.7",
        "ezyang/htmlpurifier": "^4.17",
        "guzzlehttp/guzzle": "^7.2",
        "helgesverre/receipt-scanner": "^2.0",
        "laravel/framework": "^10.0",
        "laravel/jetstream": "^2.8",
        "laravel/sanctum": "^3.2",
        "laravel/tinker": "^2.7",
        "league/flysystem-sftp-v3": "^3.19",
        "livewire/livewire": "^2.5",
        "nahid/talk": "^2.4",
        "openai-php/laravel": "^0.7.0",
        "org_heigl/ghostscript": "^2.4",
        "phpoffice/phpspreadsheet": "^1.29",
        "spatie/laravel-permission": "^5.10",
        "spatie/pdf-to-image": "^1.2",
        "spatie/pdf-to-text": "^1.52",
        "symfony/expression-language": "^7.3",
        "webklex/laravel-imap": "^5.3",
        "worksome/company-info": "^1.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^6.1",
        "phpunit/phpunit": "^9.5.10",
        "pixinvent/frest-html-laravel-jetstream": "dev-master",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
